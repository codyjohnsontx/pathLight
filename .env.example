# Pathlight environment configuration. Copy to `.env.local` (app config) and set
# DATABASE_URL in `.env` (Prisma reads `.env`). Everything has safe defaults —
# the app runs with NO configuration using the mock AI + mock Bible provider.

# ----------------------------------------------------------------------------
# AI provider
# ----------------------------------------------------------------------------
# AI_PROVIDER: "mock" (default, no network) or "llama" (any OpenAI-compatible
# endpoint). "groq" / "ollama" / "openai" are also accepted as aliases for llama.
AI_PROVIDER=mock

# For AI_PROVIDER=llama, point these at a free Llama endpoint:
#
#   Groq (hosted, free tier):
#     AI_BASE_URL=https://api.groq.com/openai/v1
#     AI_API_KEY=gsk_your_groq_key
#     AI_MODEL=llama-3.3-70b-versatile
#
#   Ollama (fully local, free — run `ollama serve` and `ollama pull llama3.1`):
#     AI_BASE_URL=http://localhost:11434/v1
#     AI_API_KEY=ollama
#     AI_MODEL=llama3.1
#
# AI_BASE_URL=
# AI_API_KEY=
# AI_MODEL=

# ----------------------------------------------------------------------------
# Bible text provider
# ----------------------------------------------------------------------------
# BIBLE_PROVIDER: "mock" (default, placeholder text) or "apibible" (API.Bible).
BIBLE_PROVIDER=mock
# For BIBLE_PROVIDER=apibible, get a free key at https://scripture.api.bible:
# BIBLE_API_KEY=
# BIBLE_ID=9879dbb7cfe39e4d-01

# ----------------------------------------------------------------------------
# Database (Prisma) — only needed for post-MVP features (accounts, saving).
# Set this in `.env` (not `.env.local`); Prisma reads `.env`.
# ----------------------------------------------------------------------------
# DATABASE_URL="postgresql://user:password@localhost:5432/pathlight?schema=public"
