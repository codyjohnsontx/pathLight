// Pathlight database schema.
//
// NOTE: The MVP ask-flow does NOT use the database — it runs entirely on the
// local curated passage index and (mock or Llama) AI. This schema is scaffolded
// for the post-MVP features (accounts, saved passages, saved reflections,
// collections). PrismaClient connects lazily, so the app boots and the ask-flow
// works with no running Postgres; you only need a database once you wire these
// models into a feature.
//
// To use it later:
//   1. Set DATABASE_URL in .env to a real Postgres connection string.
//   2. Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  savedPassages    SavedPassage[]
  savedReflections SavedReflection[]
  collections      Collection[]
}

/// A passage a user has saved for later (referenced by its canonical string).
model SavedPassage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reference String // e.g. "James 1:2-4"
  note      String?
  createdAt DateTime @default(now())

  @@unique([userId, reference])
  @@index([userId])
}

/// A written reflection, optionally tied to the question and/or a passage.
model SavedReflection {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question  String? // the life-situation question that prompted it
  reference String? // optional passage this reflection is tied to
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

/// A named collection of passages (e.g. "Job search", "Grief").
model Collection {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime         @default(now())
  items     CollectionItem[]

  @@index([userId])
}

model CollectionItem {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  reference    String
  createdAt    DateTime   @default(now())

  @@unique([collectionId, reference])
  @@index([collectionId])
}
